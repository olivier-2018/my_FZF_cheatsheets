# sudo - execute command with superuser privileges


sudo --help # sudo - execute a command as another user

# usage: sudo -h | -K | -k | -V
# usage: sudo -v [-ABkNnS] [-g group] [-h host] [-p prompt] [-u user]
# usage: sudo -l [-ABkNnS] [-g group] [-h host] [-p prompt] [-U user]
#             [-u user] [command [arg ...]]
# usage: sudo [-ABbEHkNnPS] [-r role] [-t type] [-C num] [-D directory]
#             [-g group] [-h host] [-p prompt] [-R directory] [-T timeout]
#             [-u user] [VAR=value] [-i | -s] [command [arg ...]]
# usage: sudo -e [-ABkNnS] [-r role] [-t type] [-C num] [-D directory]
#             [-g group] [-h host] [-p prompt] [-R directory] [-T timeout]
#             [-u user] file ...

# Options:
#   -A, --askpass                 use a helper program for password prompting
#   -b, --background              run command in the background
#   -B, --bell                    ring bell when prompting
#   -C, --close-from=num          close all file descriptors >= num
#   -D, --chdir=directory         change the working directory before running
#                                 command
#   -E, --preserve-env            preserve user environment when running command
#       --preserve-env=list       preserve specific environment variables
#   -e, --edit                    edit files instead of running a command
#   -g, --group=group             run command as the specified group name or ID
#   -H, --set-home                set HOME variable to target user's home dir
#   -h, --help                    display help message and exit
#   -h, --host=host               run command on host (if supported by plugin)
#   -i, --login                   run login shell as the target user; a command
#                                 may also be specified
#   -K, --remove-timestamp        remove timestamp file completely
#   -k, --reset-timestamp         invalidate timestamp file
#   -l, --list                    list user's privileges or check a specific
#                                 command; use twice for longer format
#   -n, --non-interactive         non-interactive mode, no prompts are used
#   -P, --preserve-groups         preserve group vector instead of setting to
#                                 target's
#   -p, --prompt=prompt           use the specified password prompt
#   -R, --chroot=directory        change the root directory before running command
#   -r, --role=role               create SELinux security context with specified
#                                 role
#   -S, --stdin                   read password from standard input
#   -s, --shell                   run shell as the target user; a command may
#                                 also be specified
#   -t, --type=type               create SELinux security context with specified
#                                 type
#   -T, --command-timeout=timeout terminate command after the specified time limit
#   -U, --other-user=user         in list mode, display privileges for user
#   -u, --user=user               run command (or edit file) as specified user
#                                 name or ID
#   -V, --version                 display version information and exit
#   -v, --validate                update user's timestamp without running a
#                                 command
#   --                            stop processing command line arguments



  
sudo command # [Basic] - Run command as root

    # Execute single command with elevated privileges
sudo -i # [Login Shell] - Interactive root shell

    # Start interactive root session (login shell)
sudo -s # [Shell] - Shell as root

    # Interactive root shell (non-login)
sudo su # [Switch User] - Become root

    # Switch to root user (alternate method)
sudo su - # [Root Login] - Login as root

    # Root login shell (load environment)
sudo -u username command # [User Switch] - Run as specific user

    # Execute command as different user
sudo -u www-data ls /home # [Web User] - Run as www-data

    # Execute with web server user privileges



sudo visudo # [Config] - Edit sudoers safely

    # Edit sudo configuration with syntax checking
sudo cat /etc/sudoers # [View] - Show sudo configuration

    # Display current sudo rules (read-only, use visudo to edit)
sudo -l # [List] - Show allowed commands

    # Display what commands current user can run with sudo
sudo -lU username # [User Permissions] - Check user's permissions

    # Show what specific user can run with sudo
sudo -v # [Validate] - Extend sudo timeout

    # Refresh sudo credentials (extends timeout)
sudo -k # [Clear] - Clear sudo credentials

    # Invalidate cached credentials (re-prompt for password)



sudo -H command # [Home] - Set HOME variable

    # Run with target user's home directory
sudo -E command # [Environment] - Preserve environment

    # Keep current environment variables
sudo -i command # [Login] - Login shell for command

    # Execute in login shell context
sudo -n command # [Non-interactive] - No password prompt

    # Run without password (for scripts, must be configured)
sudo -e file # [Edit] - Edit file as root

    # Safely edit file with elevated privileges
sudo tee file # [Write] - Write to protected file

    # Redirect output to protected file
sudo -s << 'EOF' # [Heredoc] - Multi-line commands

    # Execute multiple commands in root shell
sudo bash -c 'command1; command2' # [Multiple] - Multiple commands

    # Run sequential commands with single sudo



sudo passwd # [Change Password] - Change own password

    # Update your password
sudo passwd username # [User Password] - Change user password

    # Reset another user's password
sudo !! # [Repeat] - Repeat last command with sudo

    # Quickly re-run failed command with privileges
sudo -u user -i pwd # [Verify User] - Verify privilege level

    # Check effective user ID
sudo whoami # [Who Am I] - Show effective user

    # Display current effective user (root)
id # [Without sudo] - Show current user

    # Display actual user (not sudo'd)
sudo id # [With sudo] - Show sudo'd user

    # Show root UID/GID



visudo # [Alt Config] - Alternative sudoers editor

    # Edit with sudo checks (if sudo not needed for own user)
sudo systemctl restart service # [System Command] - Restart service

    # Common administrative task with sudo
sudo apt-get install package # [Package Manager] - Install package

    # Install software with privileges
sudo reboot # [System Control] - Reboot system

    # Restart system with sudo
sudo shutdown -h now # [Shutdown] - Immediate shutdown

    # Halt system immediately
