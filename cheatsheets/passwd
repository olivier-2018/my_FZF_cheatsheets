# passwd - change user passwords and password policy

passwd # [Change Password] - Change own password

    # Interactively update current user's password
passwd username # [User Password] - Change user's password

    # Update password for specific user (requires root)
passwd -l username # [Lock] - Lock user account

    # Disable login (root only)
passwd -u username # [Unlock] - Unlock user account

    # Re-enable previously locked account
passwd -d username # [Remove Password] - Delete password

    # Allow login without password (rarely used)
passwd -e username # [Expire] - Force password change

    # Require user to change password at next login
passwd -S username # [Status] - Show password status

    # Display password age and lock status



passwd -n 7 username # [Min Days] - Minimum days before change

    # User must wait 7 days before changing again
passwd -x 90 username # [Max Days] - Maximum days before change required

    # Force password change after 90 days
passwd -w 14 username # [Warning] - Warning days before expiry

    # Warn user 14 days before expiry
passwd -i 7 username # [Inactive] - Days after expiry to disable

    # Disable account 7 days after password expires
chage -l username # [Age Info] - Display password age

    # Show password expiration and policy
chage -d 0 username # [Last Changed] - Force immediate change

    # Set last change to today (require change next login)
chage -E 2025-12-31 username # [Expiry Date] - Set absolute expiry

    # Account expires on specific date



sudo passwd -d username # [Remove Password] - Delete password (root)

    # Allow password-less login
sudo passwd username # [Reset Password] - Reset user password

    # Generate temporary password for user
echo "newpassword" | passwd --stdin username # [Script] - Non-interactive password

    # Set password from stdin (requires --stdin flag)
openssl passwd # [Generate Hash] - Generate password hash

    # Create bcrypt password hash
mkpasswd # [Generate] - Generate random password

    # Create strong random password
passwd -a # [All Users] - Show all users' status

    # Display password info for all users (root)
