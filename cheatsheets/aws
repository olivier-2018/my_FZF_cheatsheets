aws s3 ls # [S3] - Scalable object storage with high availability

    # List all S3 buckets in your account
aws s3 ls s3://bucket-name/ # [S3] - Scalable object storage with high availability

    # List objects in bucket; supports --recursive for full tree
aws s3 cp file.txt s3://bucket-name/ # [S3] - Scalable object storage with high availability

    # Upload file to S3 bucket
aws s3 cp s3://bucket-name/file.txt . # [S3] - Scalable object storage with high availability

    # Download file from S3 bucket to current directory
aws s3 cp s3://bucket-name/src s3://bucket-name/dest --recursive # [S3] - Scalable object storage with high availability

    # Copy objects within S3; use --recursive for directories
aws s3 sync ./dir s3://bucket-name/ # [S3] - Scalable object storage with high availability

    # Bidirectional sync; upload new/changed files only (efficient)
aws s3 sync s3://bucket-name/ ./dir # [S3] - Scalable object storage with high availability

    # Download all objects from S3 to local directory
aws s3 rm s3://bucket-name/file.txt # [S3] - Scalable object storage with high availability

    # Delete single object from S3
aws s3 rm s3://bucket-name/ --recursive # [S3] - Scalable object storage with high availability

    # Delete all objects in bucket; cannot delete bucket itself
aws s3 mv s3://src-bucket/file s3://dst-bucket/ # [S3] - Scalable object storage with high availability

    # Move/rename object within or between buckets
aws s3 presign s3://bucket-name/file.txt # [S3] - Scalable object storage with high availability

    # Generate pre-signed URL for temporary public access



