awk '{print}' file.txt # [Basic Output] - Print every line

    # Output entire line (same as cat)
awk '{print $1}' file.txt # [Basic Output] - Print first field

    # Extract first column (space-separated by default)
awk '{print $1, $3}' file.txt # [Basic Output] - Print multiple fields

    # Extract columns 1 and 3 with space separator
awk '{print $NF}' file.txt # [Basic Output] - Print last field

    # $NF references final field regardless of column count
awk '{print $(NF-1)}' file.txt # [Basic Output] - Print second-to-last field

    # Reference field by expression (column count minus 1)
awk '{print NR, $0}' file.txt # [Basic Output] - Print line number and line

    # NR = current line number; $0 = entire line



awk 'BEGIN {print "Header"}' file.txt # [BEGIN/END] - Execute before processing

    # BEGIN block runs once before reading input
awk 'END {print "Total: " NR}' file.txt # [BEGIN/END] - Execute after processing

    # END block runs after all lines processed; print total lines
awk 'BEGIN {FS=":"} {print $1}' file.txt # [BEGIN/END] - Set field separator

    # BEGIN changes separator before reading (colon for /etc/passwd)
awk 'BEGIN {OFS=","} {print $1, $2, $3}' file.txt # [BEGIN/END] - Set output separator

    # Output fields joined by comma instead of space
awk 'BEGIN {ORS="|"} {print}' file.txt # [BEGIN/END] - Set output record separator

    # Records joined by | instead of newline
awk 'BEGIN {RS=";"} {print NR, $0}' file.txt # [BEGIN/END] - Set input record separator

    # Treat semicolon as line separator (not newline)



awk '/pattern/' file.txt # [Pattern Matching] - Print lines matching pattern

    # Extract lines containing pattern (like grep)
awk '!/pattern/' file.txt # [Pattern Matching] - Print non-matching lines

    # Show lines NOT containing pattern
awk '/start/,/end/' file.txt # [Pattern Matching] - Print between patterns

    # Output from start pattern to end pattern (inclusive)
awk '/pattern1/ || /pattern2/' file.txt # [Pattern Matching] - Match multiple patterns (OR)

    # Print lines matching either pattern
awk '/pattern1/ && /pattern2/' file.txt # [Pattern Matching] - Match both patterns (AND)

    # Print only if line matches both patterns
awk 'NR==5' file.txt # [Pattern Matching] - Match specific line number

    # Print only line 5



awk '$1 == "admin"' file.txt # [Conditional] - Match field value

    # Print lines where first field equals "admin"
awk '$2 > 100' file.txt # [Conditional] - Numeric comparison

    # Print lines where second field is greater than 100
awk '$3 ~ /pattern/' file.txt # [Conditional] - Field matches regex

    # Print if third field matches pattern (~ operator)
awk '$3 !~ /pattern/' file.txt # [Conditional] - Field doesn't match regex

    # Print if third field does NOT match pattern
awk 'length($1) > 5' file.txt # [Conditional] - String length comparison

    # Print lines where first field is longer than 5 characters
awk '$NF ~ /\.txt$/' file.txt # [Conditional] - Last field ends with .txt

    # Print lines where last column ends with .txt extension



awk '{sum += $1} END {print sum}' file.txt # [Arithmetic] - Sum column

    # Add up all values in first column
awk '{sum += $2; count++} END {print sum/count}' file.txt # [Arithmetic] - Calculate average

    # Compute average of second column
awk '{prod *= $1} END {print prod}' file.txt # [Arithmetic] - Multiply column

    # Multiply all values in first column
awk '$1 > max {max = $1} END {print max}' file.txt # [Arithmetic] - Find maximum

    # Track highest value in column 1
awk '$1 < min || NR == 1 {min = $1} END {print min}' file.txt # [Arithmetic] - Find minimum

    # Track lowest value (skip on first line check)



awk '{for(i=1; i<=NF; i++) print $i}' file.txt # [Loops] - Loop over fields

    # Process each field separately (print each on own line)
awk 'BEGIN {for(i=1; i<=10; i++) print i}' # [Loops] - Print numbers 1-10

    # Generate sequence using for loop
awk '{while(i++ < NF) print $i}' file.txt # [Loops] - While loop example

    # Iterate through fields with while
awk '{for(i in array) print i}' # [Loops] - Loop over array keys

    # Iterate through associative array indices
awk 'BEGIN {for(i=0; i<3; i++) for(j=0; j<3; j++) print i,j}' # [Loops] - Nested loops

    # Cartesian product (3x3 grid of pairs)
