    # Execute at least once, then repeat while condition



awk '{a[$1]++} END {for(k in a) print k, a[k]}' file.txt # [Arrays] - Count occurrences

    # Tally how many times each first field value appears
awk '{lines[$1] = $0} END {for(k in lines) print k, lines[k]}' file.txt # [Arrays] - Store lines by key

    # Store entire line with first field as key
awk 'BEGIN {a[1]="one"; a[2]="two"; a[3]="three"} {print a[$1]}' file.txt # [Arrays] - Lookup table

    # Use array as dictionary for value translation
awk '{split($0, a, ","); print a[2]}' file.txt # [Arrays] - Split line into array

    # Split CSV line by comma; access second field
awk '{n=split($0, a, ":"); for(i=1; i<=n; i++) print a[i]}' file.txt # [Arrays] - Process delimited fields

    # Split and loop through all resulting fields
