# lsof - list open files and network connections

lsof (man) #  usage: [-?abhKlnNoOPRtUvVX] [+|-c c] [+|-d s] [+D D] [+|-E] [+|-e s] [+|-f[gG]]
#  [-F [f]] [-g [s]] [-i [i]] [+|-L [l]] [+m [m]] [+|-M] [-o [o]] [-p s]
#  [+|-r [t]] [-s [p:s]] [-S [t]] [-T [t]] [-u s] [+|-w] [-x [fl]] [--] [names]

# Defaults in parentheses; comma-separated set (s) items; dash-separated ranges.
#   -?|-h list help          -a AND selections (OR)     -b avoid kernel blocks
#   -c c  cmd c ^c /c/[bix]  +c w  COMMAND width (9)    +d s  dir s files
#   -d s  select by FD set   +D D  dir D tree *SLOW?*   +|-e s  exempt s *RISKY*
#   -i select IPv[46] files  -K [i] list|(i)gn tasKs    -l list UID numbers
#   -n no host names         -N select NFS files        -o list file offset
#   -O no overhead *RISKY*   -P no port names           -Q allow failed search
#   -R list paRent PID       -s list file size          -t terse listing
#   -T disable TCP/TPI info  -U select Unix socket      -v list version info
#   -V verbose search        +|-w  Warnings (+)         -X skip TCP&UDP* files
#   -Z Z  context [Z]        -- end option scan
#   -E display endpoint info              +E display endpoint info and files
#   +f|-f  +filesystem or -file names     +|-f[gG] flaGs
#   -F [f] select fields; -F? for help
#   +|-L [l] list (+) suppress (-) link counts < l (0 = all; default = 0)
#                                         +m [m] use|create mount supplement
#   +|-M   portMap registration (-)       -o o   o 0t offset digits (8)
#   -p s   exclude(^)|select PIDs         -S [t] t second stat timeout (15)
#   -T fqs TCP/TPI Fl,Q,St (s) info
#   -g [s] exclude(^)|select and print process group IDs
#   -i i   select by IPv[46] address: [46][proto][@host|addr][:svc_list|port_list]
#   +|-r [t[m<fmt>]] repeat every t seconds (15);  + until no files, - forever.
#        An optional suffix to t is m<fmt>; m must separate t from <fmt> and
#       <fmt> is an strftime(3) format for the marker line.
#   -s p:s  exclude(^)|select protocol (p = TCP|UDP) states by name(s).
#   -u s   exclude(^)|select login|UID set s
#   -x [fl] cross over +d|+D File systems or symbolic Links
#   names  select named files or files on named file systems




lsof # [All] - List all open files and sockets

    # Display all open file descriptors system-wide
lsof -i # [Network] - Show network connections

    # Display open network sockets (TCP/UDP)
lsof -i :80 # [Port] - Connections on port 80

    # Show what's using HTTP port
lsof -i :443 # [HTTPS] - Port 443 connections

    # Show HTTPS traffic
lsof -i TCP # [TCP] - TCP connections only

    # Display all TCP sockets
lsof -i UDP # [UDP] - UDP connections only

    # Display all UDP sockets
lsof -p 1234 # [PID] - Files for process 1234

    # Show all open files for specific process
lsof -u username # [User] - Files opened by user

    # List open files owned by user
lsof -c process_name # [Command] - By process name

    # Files opened by named process



lsof /path/to/file # [File] - Who has file open

    # Find processes accessing specific file
lsof /home # [Directory] - Files in directory

    # Show what has directory open
lsof | grep deleted # [Deleted] - Deleted open files

    # Find files deleted but still open
lsof -a -u username -i TCP # [Combine] - User's TCP connections

    # User's network sockets only
lsof -r 1 # [Repeat] - Refresh every 1 second

    # Continuous monitoring mode
lsof +D /home # [Recursive] - Recursive directory

    # Show all open files in directory tree
lsof -n # [Numeric] - No hostname resolution

    # Display IPs instead of hostnames
lsof -P # [Numeric Ports] - No service name resolution

    # Show port numbers instead of names



lsof -l # [UID] - Show UID instead of username

    # Numeric user IDs in output
lsof -s # [File Size] - Show file size

    # Include file size column
lsof -X # [Avoid Warnings] - Suppress warnings

    # Don't warn about access errors
lsof -t -i :22 # [PID Only] - Just PID for port 22

    # Extract process ID only
lsof -i :22 -n -P # [SSH Connection] - SSH details

    # Show SSH connections with IPs and port numbers
netstat -an | grep LISTEN # [Alternative] - Use netstat for listening

    # Alternative view of listening ports
ss -ltnp # [ss Alternative] - Modern socket stats

    # Modern replacement for some lsof uses
