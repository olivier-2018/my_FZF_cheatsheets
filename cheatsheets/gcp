gcp compute security-policies list # [Security] - DDoS and web attack protection

    # List all security policies
gcp compute security-policies create <name> # [Security] - Create security policy

    # Create Cloud Armor policy for DDoS/WAF
gcp compute security-policies rules create 1000 --security-policy <policy> --action deny-403 --expression "origin.region_code == 'CN'" # [Security] - Add policy rule

    # Add rule to block traffic by criteria
gcp compute security-policies delete <name> # [Security] - Delete security policy

    # Remove security policy
gcp compute network-attachments list # [Security] - Private service connections

    # List network attachments
gcp compute packet-mirrorings list # [Security] - Mirror network traffic for monitoring

    # List traffic mirroring policies



gcp secrets create <name> --data-file=file.txt # [Security - Secret Manager] - Secure storage for secrets and credentials

    # Create secret from file
gcp secrets versions access latest --secret=<name> # [Security - Secret Manager] - Retrieve secret value

    # Get current secret version
gcp secrets delete <name> # [Security - Secret Manager] - Delete secret

    # Remove secret (versions remain temporarily)
gcp secrets list # [Security - Secret Manager] - List all secrets

    # Show all stored secrets
gcp secrets versions list <name> # [Security - Secret Manager] - List secret versions

    # Show all versions of a secret
gcp secrets add-iam-policy-binding <name> --member=user:<email> --role=roles/secretmanager.secretAccessor # [Security - Secret Manager] - Grant secret access

